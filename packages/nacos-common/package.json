{
  "name": "nacos-common",
  "version": "2.6.2",
  "description": "nacos common types and transport abstractions",
  "keywords": [
    "nacos",
    "nacos-common"
  ],
  "main": "dist/index.js",
  "author": "gxcsoccer <gxcsoccer@126.com>",
  "dependencies": {
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.0",
    "address": "^1.2.2"
  },
  "optionalDependencies": {
    "@nacos-group/sdk-proto": "^1.0.0-beta.7"
  },
  "devDependencies": {
    "@types/mocha": "^5.2.5",
    "@types/node": "^10.9.4",
    "midway-bin": "1",
    "tslint": "^5.11.0",
    "typescript": "^3.2.2"
  },
  "engines": {
    "node": ">= 8.0.0"
  },
  "scripts": {
    "lint": "tslint . --ext .ts",
    "test": "npm run test-local",
